#!/bin/bash
# turbo1bit-server — OpenAI-compatible API server for Bonsai models with KV compression
#
# Wraps llama-server with auto-configured KV cache compression and Flash Attention.
# Provides /v1/chat/completions, /v1/completions, and /v1/models endpoints.
#
# Usage:
#   turbo1bit-server <model.gguf> [options]
#   turbo1bit-server models/Bonsai-8B-gguf/Bonsai-8B.gguf --ctx 65536 --port 8080
#   turbo1bit-server models/Bonsai-1.7B-gguf/Bonsai-1.7B.gguf --kv q5_0

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVER_BIN="$SCRIPT_DIR/bonsai-llama.cpp/build/bin/llama-server"

# Defaults
PORT=8080
CTX=8192
KV_TYPE="q4_0"
HOST="127.0.0.1"
N_PARALLEL=1

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    echo "Usage: turbo1bit-server <model.gguf> [options]"
    echo ""
    echo "Options:"
    echo "  --port N       Server port (default: 8080)"
    echo "  --ctx N        Context size (default: 8192)"
    echo "  --kv TYPE      KV cache type: q4_0, q5_0, q8_0, f16 (default: q4_0)"
    echo "  --host ADDR    Bind address (default: 127.0.0.1)"
    echo "  --parallel N   Number of parallel slots (default: 1)"
    echo "  -h, --help     Show this help"
    echo ""
    echo "Examples:"
    echo "  turbo1bit-server Bonsai-8B.gguf                          # 8K ctx, Q4_0"
    echo "  turbo1bit-server Bonsai-8B.gguf --ctx 65536              # Full 65K"
    echo "  turbo1bit-server Bonsai-1.7B.gguf --kv q5_0 --port 3000 # Custom port"
    echo ""
    echo "API endpoints (OpenAI-compatible):"
    echo "  POST /v1/chat/completions    Chat completion"
    echo "  POST /v1/completions         Text completion"
    echo "  GET  /v1/models              List models"
    echo ""
    echo "Test with curl:"
    echo "  curl http://localhost:8080/v1/chat/completions \\"
    echo "    -H 'Content-Type: application/json' \\"
    echo "    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"Hello!\"}]}'"
}

MODEL=""

# Parse args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --port)    PORT="$2"; shift 2 ;;
        --ctx)     CTX="$2"; shift 2 ;;
        --kv)      KV_TYPE="$2"; shift 2 ;;
        --host)    HOST="$2"; shift 2 ;;
        --parallel) N_PARALLEL="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *)
            if [[ -z "$MODEL" && -f "$1" ]]; then
                MODEL="$1"
            else
                echo "Unknown option: $1"
                usage
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$MODEL" ]]; then
    echo "Error: model file required"
    usage
    exit 1
fi

# Check server binary
if [[ ! -f "$SERVER_BIN" ]]; then
    echo -e "${YELLOW}Building llama-server...${NC}"
    cd "$SCRIPT_DIR/bonsai-llama.cpp"
    mkdir -p build && cd build
    cmake .. -G Ninja -DGGML_METAL=ON -DCMAKE_BUILD_TYPE=Release -DLLAMA_BUILD_SERVER=ON 2>/dev/null
    ninja llama-server 2>&1 | tail -3
    cd "$SCRIPT_DIR"
fi

# Detect available RAM
if [[ "$(uname)" == "Darwin" ]]; then
    RAM_GB=$(($(sysctl -n hw.memsize) / 1024 / 1024 / 1024))
else
    RAM_GB=$(($(grep MemTotal /proc/meminfo | awk '{print $2}') / 1024 / 1024))
fi

# Calculate estimated memory
MODEL_SIZE_MB=$(du -m "$MODEL" | cut -f1)
echo -e "${CYAN}════════════════════════════════════════${NC}"
echo -e "${CYAN}  Turbo1Bit Server${NC}"
echo -e "${CYAN}════════════════════════════════════════${NC}"
echo ""
echo -e "  Model:    $(basename "$MODEL") (${MODEL_SIZE_MB} MiB)"
echo -e "  Context:  ${CTX} tokens"
echo -e "  KV cache: ${GREEN}${KV_TYPE}${NC} (Flash Attention enabled)"
echo -e "  RAM:      ${RAM_GB} GB available"
echo -e "  Parallel: ${N_PARALLEL} slot(s)"
echo ""
echo -e "  Server:   ${GREEN}http://${HOST}:${PORT}${NC}"
echo -e "  API:      ${GREEN}http://${HOST}:${PORT}/v1/chat/completions${NC}"
echo ""
echo -e "  Test: curl http://${HOST}:${PORT}/v1/chat/completions \\"
echo -e "    -H 'Content-Type: application/json' \\"
echo -e "    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"Hello!\"}]}'"
echo ""
echo -e "${CYAN}════════════════════════════════════════${NC}"
echo ""

# Build server args
SERVER_ARGS=(
    -m "$MODEL"
    --port "$PORT"
    --host "$HOST"
    -c "$CTX"
    -np "$N_PARALLEL"
    -fa on
)

# Add KV quantization if not FP16
if [[ "$KV_TYPE" != "f16" ]]; then
    SERVER_ARGS+=(-ctk "$KV_TYPE" -ctv "$KV_TYPE")
fi

echo -e "${YELLOW}Starting server...${NC}"
exec "$SERVER_BIN" "${SERVER_ARGS[@]}"
